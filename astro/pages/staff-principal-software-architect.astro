---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { breadcrumbSchema, webpageSchema } from '../utils/seo';

const title = 'Staff And Principal Software Architect | Gary McKeever';
const description = 'How Gary McKeever approaches staff and principal software architecture work: technical direction, modernization strategy, platform decisions, and delivery-safe change.';
const schema = [
  webpageSchema({ title, description, path: '/staff-principal-software-architect' }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Staff And Principal Software Architect', path: '/staff-principal-software-architect' }
  ])
];

const themes = [
  {
    title: 'Architecture direction',
    text: 'Set the technical direction that lets teams move with fewer collisions, better runtime behavior, and clearer tradeoffs.'
  },
  {
    title: 'Modernization strategy',
    text: 'Turn risky platform constraints into staged plans the organization can actually execute while product work continues.'
  },
  {
    title: 'Organizational leverage',
    text: 'Improve local development, delivery standards, and platform patterns so teams solve business problems instead of rebuilding infrastructure ad hoc.'
  }
];

const prompts = [
  {
    question: 'What does staff-level architecture look like?',
    answer: 'Staff-level architecture stabilizes delivery. It reduces coupling, improves operational clarity, and creates technical direction teams can use immediately.'
  },
  {
    question: 'What shifts at principal-level scope?',
    answer: 'Principal-level scope expands the same work across larger organizational boundaries: cross-team migration strategy, platform standards, and architecture decisions that affect entire product areas.'
  },
  {
    question: 'Where do I fit?',
    answer: 'My work sits across both scopes: close enough to system behavior to make the hard technical calls, and broad enough to shape platform direction without losing delivery realism.'
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://garymckeever.us/staff-principal-software-architect"
  keywords={['staff software architect', 'principal software architect', 'architecture leadership', 'platform architecture', 'distributed systems architect']}
  schema={schema}
>
  <section class="topic-hero">
    <p class="eyebrow">Role Scope</p>
    <h1>Staff And Principal Software Architecture Work</h1>
    <p class="lead">The title matters less than the scope: making architecture decisions that improve how software ships, runs, and changes over time. My work is strongest where platform direction and delivery pressure meet.</p>
  </section>

  <section>
    <h2 class="section-heading">What I Am Usually Brought In To Do</h2>
    <div class="theme-grid">
      {themes.map((theme) => (
        <article class="theme-card">
          <h3>{theme.title}</h3>
          <p>{theme.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2 class="section-heading">Direct Answers</h2>
    <div class="prompt-grid">
      {prompts.map((prompt) => (
        <article class="prompt-card">
          <h3>{prompt.question}</h3>
          <p>{prompt.answer}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2 class="section-heading">What That Means In Practice</h2>
    <div class="topic-callout">
      <p>The practical work usually includes migration sequencing, runtime and infrastructure decisions, architectural boundary-setting, and the engineering standards that help teams keep shipping while core systems evolve.</p>
      <div class="actions">
        <a class="btn primary" href="/#journey"><Icon name="chart" /> Career progression</a>
        <a class="btn" href="/platform-modernization"><Icon name="arrow" /> Modernization approach</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .theme-grid,
  .prompt-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .theme-card,
  .prompt-card,
  .topic-callout {
    padding: 1.2rem;
    border: 1px solid color-mix(in srgb, var(--border), transparent 15%);
    border-radius: 18px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt), transparent 8%), var(--surface-soft));
  }

  .theme-card h3,
  .prompt-card h3 {
    margin-bottom: 0.7rem;
  }

  @media (max-width: 900px) {
    .theme-grid,
    .prompt-grid {
      grid-template-columns: 1fr;
    }
  }
</style>