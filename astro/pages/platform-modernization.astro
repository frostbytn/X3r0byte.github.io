---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { breadcrumbSchema, webpageSchema } from '../utils/seo';

const title = 'Platform Modernization | Gary McKeever';
const description = 'A practical view of platform modernization: staged change, controlled migrations, and architecture decisions that reduce risk without freezing delivery.';
const schema = [
  webpageSchema({ title, description, path: '/platform-modernization' }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Platform Modernization', path: '/platform-modernization' }
  ])
];

const pillars = [
  {
    title: 'Start with operational friction',
    text: 'Modernization should begin where delivery is currently expensive or risky: brittle release paths, runtime blind spots, tight coupling, or shared infrastructure that blocks independent change.'
  },
  {
    title: 'Move in reversible steps',
    text: 'The best modernization work reduces blast radius first. Carve seams, add compatibility layers, and make rollout decisions reversible before chasing ideal end-state diagrams.'
  },
  {
    title: 'Treat architecture as delivery infrastructure',
    text: 'Modernization succeeds when architecture decisions make shipping easier, not when they become an excuse to pause product work for a long rewrite program.'
  }
];

const signals = [
  'Revenue-critical systems on unsupported or end-of-life foundations',
  'Cross-team changes that stall because too much behavior is coupled together',
  'Fragile release processes, manual operational steps, and runtime uncertainty',
  'Business pressure to move faster while core systems still need to evolve'
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://garymckeever.us/platform-modernization"
  keywords={['platform modernization', 'legacy modernization', 'strangler pattern', 'migration strategy', 'software architecture']}
  schema={schema}
>
  <section class="topic-hero">
    <p class="eyebrow">Focus Area</p>
    <h1>Platform Modernization Without Delivery Paralysis</h1>
    <p class="lead">I approach modernization as a delivery problem, not just a code problem. The point is to reduce risk, improve system shape, and keep the business moving while the platform evolves.</p>
  </section>

  <section>
    <h2 class="section-heading">What Good Modernization Looks Like</h2>
    <div class="pillar-grid">
      {pillars.map((pillar) => (
        <article class="pillar-card">
          <h3>{pillar.title}</h3>
          <p>{pillar.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section>
    <h2 class="section-heading">When Teams Usually Need Help</h2>
    <ul class="topic-list">
      {signals.map((signal) => (
        <li>{signal}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2 class="section-heading">Operating Model</h2>
    <div class="topic-callout">
      <p>I look for the place where architecture is currently making delivery harder than it needs to be. From there the sequence is usually the same:</p>
      <ol>
        <li>Reduce blast radius and create clearer boundaries.</li>
        <li>Improve confidence in change with better runtime and deployment shape.</li>
        <li>Move critical behavior onto a stronger long-term foundation without forcing a stop-the-world rewrite.</li>
      </ol>
    </div>
    <div class="actions">
      <a class="btn primary" href="/#work"><Icon name="chart" /> See where this shows up</a>
      <a class="btn" href="/staff-principal-software-architect"><Icon name="arrow" /> Staff and Principal scope</a>
    </div>
  </section>
</BaseLayout>

<style>
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .pillar-card,
  .topic-callout {
    padding: 1.2rem;
    border: 1px solid color-mix(in srgb, var(--border), transparent 15%);
    border-radius: 18px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--surface-alt), transparent 8%), var(--surface-soft));
  }

  .pillar-card h3 {
    margin-bottom: 0.7rem;
  }

  .topic-list {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.75rem;
  }

  .topic-callout ol {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.45rem;
  }

  @media (max-width: 900px) {
    .pillar-grid {
      grid-template-columns: 1fr;
    }
  }
</style>