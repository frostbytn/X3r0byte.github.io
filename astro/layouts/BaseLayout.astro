---
import '../styles/global.css';
import { absoluteUrl, buildPageSchema, defaultKeywords, type SchemaInput } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  keywords?: string[];
  robots?: string;
  type?: 'website' | 'article' | 'profile';
  schema?: SchemaInput | SchemaInput[];
}

const {
  title,
  description,
  canonical,
  image = '/og-card.png',
  imageAlt = 'Gary McKeever software architecture site preview',
  keywords = [],
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  type = 'website',
  schema = []
} = Astro.props;

const canonicalUrl = canonical ?? Astro.url.href;
const socialImage = absoluteUrl(image, Astro.site ?? Astro.url);
const schemaMarkup = buildPageSchema(schema, Astro.site ?? Astro.url);
const keywordContent = [...new Set([...defaultKeywords, ...keywords])].join(', ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordContent} />
    <meta name="robots" content={robots} />
    <meta name="author" content="Gary McKeever" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Gary McKeever" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="alternate" type="application/rss+xml" title="Gary McKeever RSS" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    {schemaMarkup && <script type="application/ld+json" set:html={schemaMarkup}></script>}
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="shell">
      <header class="site-nav">
        <div class="container nav-inner">
          <a class="brand" href="/">Gary McKeever</a>
          <div class="nav-controls">
            <nav class="nav-links" aria-label="Primary">
              <a href="/#principles">How I Think</a>
              <a href="/#work">Where It Shows Up</a>
              <a href="/#journey">How I Got Here</a>
              <a href="/#projects">What I Build</a>
              <a href="/#technical">What I Work In</a>
              <a href="/#contact">Contact</a>
            </nav>
            <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle color theme" title="Toggle color theme">
              <span class="theme-toggle-icon" aria-hidden="true">◐</span>
              <span class="theme-toggle-label">Theme</span>
            </button>
          </div>
        </div>
      </header>
      <main id="main-content">
        <div class="container">
          <slot />
        </div>
      </main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <p>&copy; {new Date().getFullYear()} Gary McKeever</p>
          <nav class="footer-links" aria-label="Footer">
            <a href="/">Home</a>
            <a href="/#journey">Journey</a>
            <a href="https://github.com/X3r0byte" target="_blank" rel="noreferrer">GitHub</a>
          </nav>
        </div>
      </footer>
    </div>
    <script is:inline>
      (() => {
        const key = 'gmk-theme';
        const root = document.documentElement;
        const toggle = document.querySelector('[data-theme-toggle]');

        const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const stored = localStorage.getItem(key);
        const initial = stored === 'light' || stored === 'dark' ? stored : preferred;

        const applyTheme = (theme) => {
          root.setAttribute('data-theme', theme);
          toggle.setAttribute('aria-pressed', String(theme === 'light'));
          const label = toggle.querySelector('.theme-toggle-label');
          if (label) label.textContent = theme === 'light' ? 'Light' : 'Dark';
        };

        applyTheme(initial);

        if (toggle) {
          toggle.addEventListener('click', () => {
            const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
            localStorage.setItem(key, next);
            applyTheme(next);
          });
        }

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const pendingHashKey = 'gmk-pending-hash';

        const smoothScrollToHash = (hash) => {
          const target = document.querySelector(hash);
          if (!target) return false;

          target.scrollIntoView({
            behavior: reduceMotion ? 'auto' : 'smooth',
            block: 'start'
          });

          window.history.pushState(null, '', hash);
          return true;
        };

        const pendingHash = sessionStorage.getItem(pendingHashKey);
        if (pendingHash) {
          sessionStorage.removeItem(pendingHashKey);
          requestAnimationFrame(() => {
            smoothScrollToHash(pendingHash);
          });
        } else if (window.location.hash) {
          requestAnimationFrame(() => {
            smoothScrollToHash(window.location.hash);
          });
        }

        document.addEventListener('click', (event) => {
          const anchor = event.target.closest('a');
          if (!anchor) return;
          if (anchor.target === '_blank' || anchor.hasAttribute('download')) return;

          const href = anchor.getAttribute('href');
          if (!href || href.startsWith('mailto:') || href.startsWith('tel:')) return;

          const url = new URL(anchor.href, window.location.origin);
          const sameOrigin = url.origin === window.location.origin;
          if (!sameOrigin) return;

          const samePath = url.pathname === window.location.pathname;
          const hasHash = Boolean(url.hash);

          if (samePath && hasHash) {
            event.preventDefault();
            smoothScrollToHash(url.hash);
            return;
          }

          if (!samePath && hasHash && url.pathname === '/') {
            event.preventDefault();
            sessionStorage.setItem(pendingHashKey, url.hash);
            window.location.assign(url.pathname);
            return;
          }

          if (!reduceMotion && !samePath) {
            event.preventDefault();
            document.body.classList.add('is-leaving');
            window.setTimeout(() => {
              window.location.assign(url.href);
            }, 140);
          }
        });
      })();
    </script>
  </body>
</html>
